# ============================================================
#  Fiah Corner API — Environment Variables
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- MongoDB Atlas ---
# Buat akun gratis di https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/fiah_corner?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=ganti_dengan_random_string_panjang_dan_aman
JWT_EXPIRES_IN=7d

# --- Cloudinary (Upload Foto Menu) ---
# Daftar gratis di https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email / Nodemailer ---
# Untuk Gmail: aktifkan 2FA lalu buat "App Password"
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_FROM="Fiah Corner ☕ <your@gmail.com>"

# --- WhatsApp (Pilih salah satu provider) ---
# Provider: fonnte | cloudapi | wablas
WA_PROVIDER=fonnte

# Fonnte.com (populer di Indonesia, ada free tier)
# Daftar di https://fonnte.com
FONNTE_TOKEN=your_fonnte_token

# WhatsApp Cloud API (Official Meta, 1000 gratis/bulan)
# Setup di https://developers.facebook.com/docs/whatsapp/cloud-api
WA_CLOUD_TOKEN=your_wa_cloud_token
WA_CLOUD_PHONE_ID=your_phone_number_id
WA_CLOUD_VERSION=v20.0

# --- Nomor Admin (penerima notifikasi pesanan) ---
# Format: 628xxxxxxxxxx (tanpa + dan spasi)
ADMIN_WA_NUMBER=628123456789
ADMIN_EMAIL=admin@fiahcorner.com

# --- CORS (domain frontend yang diizinkan) ---
# Pisah dengan koma jika lebih dari satu
ALLOWED_ORIGINS=http://localhost:3000,https://fiah-corner.vercel.app
